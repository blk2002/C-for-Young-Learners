<!-- pages/admin-exercises/admin-exercises.wxml -->
<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view class="content" wx:else>
    <view class="chapter-list">
      <view
        class="chapter-card"
        wx:for="{{chapters}}"
        wx:key="_id"
        bindtap="goToLessons"
        data-chapterid="{{item._id}}"
        data-chaptertitle="{{item.title}}"
      >
        <view class="chapter-icon">📖</view>
        <view class="chapter-info">
          <view class="chapter-title">{{item.title}}</view>
          <view class="chapter-meta">序号：{{item.order}}</view>
        </view>
        <view class="chapter-arrow">›</view>
      </view>

      <view class="empty-state" wx:if="{{chapters.length === 0}}">
        <view class="icon">📚</view>
        <view class="text">暂无章节</view>
        <view class="text" style="font-size: 24rpx; margin-top: 10rpx;">请先在课程管理中添加章节</view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>