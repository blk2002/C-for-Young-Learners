<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view wx:elif="{{wrongQuestions.length === 0}}" class="empty-state">
    <view class="icon">🎉</view>
    <view class="text">暂无错题</view>
    <view class="text" style="font-size: 24rpx; margin-top: 10rpx;">太棒了，继续保持！</view>
  </view>

  <view wx:else class="practice-container">
    <view class="progress-header">
      <view class="progress-text">第 {{currentIndex + 1}} / {{wrongQuestions.length}} 题</view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
    </view>

    <view class="question-card">
      <view class="question-header">
        <view class="question-number">第 {{currentIndex + 1}} 题</view>
        <view class="question-type-tag" wx:if="{{currentQuestion.type === 'choice'}}">选择题</view>
        <view class="question-type-tag fill" wx:if="{{currentQuestion.type === 'fill'}}">填空题</view>
      </view>

      <view class="wrong-info">
        <text>已做错 {{currentWrongItem.wrongCount}} 次</text>
      </view>

      <view class="question-text">{{currentQuestion.question}}</view>

      <view class="options" wx:if="{{currentQuestion.type === 'choice'}}">
        <view
          class="option-item {{userAnswers[currentIndex] === optKey ? 'selected' : ''}} {{submitted ? 'disabled' : ''}} {{submitted && isCorrect[currentIndex] && userAnswers[currentIndex] === optKey ? 'correct' : ''}} {{submitted && !isCorrect[currentIndex] && currentQuestion.answer === optKey ? 'right-answer' : ''}}"
          wx:for="{{currentQuestion.options}}"
          wx:for-item="opt"
          wx:for-index="optKey"
          wx:key="*this"
          data-option="{{optKey}}"
          bindtap="selectOption"
        >
          <view class="option-letter">{{optKey}}</view>
          <view class="option-text">{{opt}}</view>
        </view>
      </view>

      <view class="fill-input-wrap" wx:if="{{currentQuestion.type === 'fill'}}">
        <input
          class="input {{submitted ? 'disabled' : ''}}"
          placeholder="请输入答案"
          value="{{userAnswers[currentIndex]}}"
          data-qindex="{{currentIndex}}"
          bindinput="onFillInput"
          disabled="{{submitted}}"
        />
      </view>

      <view class="result-section" wx:if="{{submitted}}">
        <view class="result-correct" wx:if="{{isCorrect[currentIndex]}}">✅ 回答正确！</view>
        <view class="result-wrong" wx:if="{{!isCorrect[currentIndex]}}">❌ 回答错误，正确答案是：{{currentQuestion.answer}}</view>
      </view>

      <view class="answer-section" wx:if="{{submitted}}">
        <view class="answer-label">✅ 答案：</view>
        <view class="answer-text" wx:if="{{currentQuestion.type === 'choice'}}">
          选项 {{currentQuestion.answer}}
          <text wx:if="{{currentQuestion.answer === 'A'}}">. {{currentQuestion.options.A}}</text>
          <text wx:if="{{currentQuestion.answer === 'B'}}">. {{currentQuestion.options.B}}</text>
          <text wx:if="{{currentQuestion.answer === 'C'}}">. {{currentQuestion.options.C}}</text>
          <text wx:if="{{currentQuestion.answer === 'D'}}">. {{currentQuestion.options.D}}</text>
        </view>
        <view class="answer-text" wx:if="{{currentQuestion.type === 'fill'}}">{{currentQuestion.answer}}</view>

        <view class="explanation-label" wx:if="{{currentQuestion.explanation}}">💡 解析：</view>
        <view class="explanation-text" wx:if="{{currentQuestion.explanation}}">{{currentQuestion.explanation}}</view>
      </view>

      <view class="master-btn" wx:if="{{submitted && isCorrect[currentIndex] && !currentWrongItem.mastered}}" bindtap="markMastered">
        ✓ 已掌握，移出错题本
      </view>
    </view>

    <view class="nav-buttons">
      <view class="nav-btn prev {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="prevQuestion">
        上一题
      </view>
      <view class="nav-btn next {{currentIndex === wrongQuestions.length - 1 ? 'disabled' : ''}}" bindtap="nextQuestion">
        下一题
      </view>
    </view>

    <view class="submit-section" wx:if="{{!submitted}}">
      <view class="submit-btn" bindtap="submitAll">
        提交全部答案
      </view>
    </view>

    <view class="submit-section" wx:else>
      <view class="result-summary">
        本次练习：共 {{wrongQuestions.length}} 题，答对 {{correctCount}} 题
      </view>
      <view class="master-all-btn" bindtap="markAllMastered">
        全部移出错题本
      </view>
    </view>

    <view class="bottom-space"></view>
  </view>
</view>
