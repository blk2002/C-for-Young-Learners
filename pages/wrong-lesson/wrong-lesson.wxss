.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.content {
  padding: 30rpx;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.lesson-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.lesson-card:active {
  background: #FFF0F0;
  transform: scale(0.98);
}

.lesson-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.lesson-info {
  flex: 1;
}

.lesson-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.lesson-meta {
  font-size: 24rpx;
  color: #FF4D4F;
}

.lesson-arrow {
  font-size: 44rpx;
  color: #CCC;
  font-weight: 300;
  margin-left: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

.bottom-space {
  height: 40rpx;
}
