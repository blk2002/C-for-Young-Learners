.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.content {
  padding: 30rpx;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.lesson-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.lesson-card:active {
  background: #F0F4F8;
  transform: scale(0.98);
}

.lesson-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.lesson-info {
  flex: 1;
  min-width: 0;
}

.lesson-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
  word-break: break-all;
}

.lesson-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.meta-left {
  flex: 1;
  min-width: 0;
}

.count-text {
  font-size: 26rpx;
  color: #999;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
  white-space: nowrap;
}

.status-tag.not-started {
  background: #F0F4F8;
  color: #8C8C8C;
}

.status-tag.in-progress {
  background: #E6F7FF;
  color: #1890FF;
}

.status-tag.completed {
  background: #F6FFED;
  color: #52C41A;
}

.status-tag.no-questions {
  background: #FFF7E6;
  color: #FA8C16;
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #F0F4F8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890FF, #40A9FF);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #1890FF;
  flex-shrink: 0;
  min-width: 70rpx;
  text-align: right;
}

.lesson-arrow {
  font-size: 48rpx;
  color: #BFBFBF;
  font-weight: 300;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

.bottom-space {
  height: 40rpx;
}
