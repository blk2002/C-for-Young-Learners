<!-- pages/chapters/chapters.wxml -->
<view class="container">
  <!-- 课程信息 -->
  <view class="course-header">
    <view class="course-title">{{courseName}} 课程</view>
    <view class="course-subtitle">共 {{chapters.length}} 个章节</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <view>加载中...</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{chapters.length === 0}}">
    <view class="icon">📖</view>
    <view class="text">暂无课程章节</view>
    <view class="text" style="font-size: 24rpx; margin-top: 10rpx;">请联系老师添加课程内容</view>
  </view>

  <!-- 章节列表 -->
  <view class="chapter-list" wx:else>
    <block wx:for="{{chapters}}" wx:key="_id" wx:for-item="chapter" wx:for-index="idx">
      <view class="chapter-item">
        <view class="chapter-header" bindtap="toggleChapter" data-id="{{chapter._id}}">
          <view class="chapter-number">第 {{idx + 1}} 章</view>
          <view class="chapter-info">
            <view class="chapter-title">{{chapter.title}}</view>
            <view class="chapter-meta">共 {{chapter.lessonCount}} 个知识点</view>
          </view>
          <view class="chapter-badge" wx:if="{{currentChapterId === chapter._id}}">📍</view>
        </view>

        <!-- 知识点列表 -->
        <view class="lesson-list">
          <view
            class="lesson-item {{currentLessonId === lesson._id ? 'active' : ''}}"
            wx:for="{{chapter.lessons}}"
            wx:key="_id"
            wx:for-item="lesson"
            data-chapter="{{chapter._id}}"
            data-lesson="{{lesson._id}}"
            data-title="{{lesson.title}}"
            bindtap="goToLesson"
          >
            <view class="lesson-icon">📝</view>
            <view class="lesson-content">
              <view class="lesson-title">{{lesson.title}}</view>
              <view class="lesson-subtitle" wx:if="{{lesson.description}}">
                {{lesson.description}}
              </view>
            </view>
            <view class="lesson-arrow">›</view>
          </view>

          <view class="empty-lesson" wx:if="{{chapter.lessons.length === 0}}">
            暂无知识点
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="bottom-space"></view>
</view>
