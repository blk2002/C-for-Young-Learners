.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.progress-bar {
  margin-bottom: 30rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  text-align: center;
}

.progress-track {
  height: 12rpx;
  background: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.question-number {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.question-type {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  color: #fff;
}

.type-choice {
  background: #4A90D9;
}

.type-fill {
  background: #52C41A;
}

.question-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 30rpx;
  word-break: break-all;
  white-space: normal;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.option-item.selected {
  background: #e6f7ff;
  border-color: #1890ff;
}

.option-item.correct {
  background: #f6ffed;
  border-color: #52c41a;
}

.option-item.wrong {
  background: #fff1f0;
  border-color: #f5222d;
}

.option-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-weight: bold;
}

.option-item.selected .option-circle {
  background: #1890ff;
  border-color: #1890ff;
  color: #fff;
}

.option-item.correct .option-circle {
  background: #52c41a;
  border-color: #52c41a;
  color: #fff;
}

.option-item.wrong .option-circle {
  background: #f5222d;
  border-color: #f5222d;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
}

.option-icon {
  margin-left: 16rpx;
  color: #52c41a;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.option-icon.wrong-icon {
  color: #f5222d;
}

.fill-input-wrap {
  margin-bottom: 20rpx;
}

.fill-input {
  width: 100%;
  height: 90rpx;
  padding: 0 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.answer-result {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.result-status {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-status.correct {
  color: #52c41a;
}

.result-status.wrong {
  color: #f5222d;
}

.answer-detail {
  background: #f0f5ff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 500;
  word-break: break-all;
}

.explanation {
  background: #fffbe6;
  padding: 20rpx;
  border-radius: 12rpx;
}

.exp-label {
  font-size: 26rpx;
  color: #d48806;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.exp-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

.nav-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.nav-btn {
  flex: 1;
  font-size: 30rpx;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
}

.prev-btn {
  background: #f5f7fa;
  color: #666;
}

.prev-btn[disabled] {
  opacity: 0.5;
}

.next-btn {
  background: #1890ff;
  color: #fff;
}

.submit-btn {
  background: #52c41a;
  color: #fff;
}

.submit-score {
  position: fixed;
  bottom: 130rpx;
  left: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
}

.score-text {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.score-rate {
  font-size: 26rpx;
  opacity: 0.9;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
