<!-- pages/study-progress/study-progress.wxml -->
<view class="container">
  <view class="header">
    <view class="title">📊 我的学习进度</view>
    <view class="subtitle">查看你在各课程中的学习情况</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view class="progress-list" wx:else>
    <view
      class="progress-card"
      wx:for="{{progressData}}"
      wx:key="courseId"
      data-id="{{item.courseId}}"
      data-name="{{item.courseName}}"
      bindtap="goToCourse"
      style="border-left: 8rpx solid {{item.color}};"
    >
      <view class="card-header">
        <view class="course-icon">{{item.icon}}</view>
        <view class="course-info">
          <view class="course-name">{{item.courseName}}</view>
          <view class="course-meta">共 {{item.totalLessons}} 个知识点</view>
        </view>
      </view>

      <view class="card-content">
        <view class="current-label">当前学习：</view>
        <view class="current-lesson">{{item.currentLessonTitle}}</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{progressData.length === 0}}">
      <view class="icon">📖</view>
      <view class="text">暂无学习记录</view>
    </view>
  </view>
</view>
