/* pages/study-progress/study-progress.wxss */
.container {
  padding: 0;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 50rpx 40rpx;
  color: #fff;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.progress-list {
  padding: 30rpx 40rpx;
}

.progress-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.progress-card:active {
  background: #F5F7FA;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.course-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.course-meta {
  font-size: 24rpx;
  color: #999;
}

.card-content {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.current-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.current-lesson {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}
