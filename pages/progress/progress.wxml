<!-- pages/progress/progress.wxml -->
<view class="container">
  <!-- 顶部课程切换 -->
  <view class="course-tabs">
    <view 
      class="tab-item {{currentCourse === 'cpp' ? 'active' : ''}}" 
      bindtap="switchCourse"
      data-course="cpp"
    >
      <text class="tab-icon">⚡</text>
      <text class="tab-text">C++</text>
    </view>
    <view 
      class="tab-item {{currentCourse === 'python' ? 'active' : ''}}" 
      bindtap="switchCourse"
      data-course="python"
    >
      <text class="tab-icon">🐍</text>
      <text class="tab-text">Python</text>
    </view>
  </view>

  <!-- 课程标题 -->
  <view class="course-header">
    <view class="course-title">{{courseInfo.name}} 习题练习</view>
    <view class="course-desc">选择练习方式，开始刷题</view>
  </view>

  <!-- 入口卡片 -->
  <view class="entry-cards">
    <!-- 章节知识点习题 -->
    <view class="entry-card" bindtap="goToChapterExercises">
      <view class="card-icon">📚</view>
      <view class="card-content">
        <view class="card-title">章节知识点习题</view>
        <view class="card-desc">按章节顺序，逐个知识点练习</view>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <!-- 等级考试习题 -->
    <view class="entry-card" bindtap="goToExamExercises">
      <view class="card-icon">🎓</view>
      <view class="card-content">
        <view class="card-title">等级考试习题</view>
        <view class="card-desc">模拟考试真题，考前冲刺练习</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>
</view>