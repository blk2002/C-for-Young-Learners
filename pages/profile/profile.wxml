<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section" bindtap="goToEditProfile">
    <view class="user-info-wrapper">
      <view class="avatar-wrapper">
        <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-default">
          <text>{{isAdmin ? '🛡️' : '🎓'}}</text>
        </view>
      </view>
      <view class="user-info">
        <view class="username">{{userInfo.nickname || userInfo.username}}</view>
        <view class="signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</view>
        <view class="role-tag">
          <text wx:if="{{isAdmin}}">🛡️ 老师</text>
          <text wx:else>🎓 学生</text>
        </view>
      </view>
      <view class="edit-arrow">›</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToProgress">
      <view class="menu-icon">📊</view>
      <view class="menu-text">学习进度</view>
      <view class="menu-arrow">›</view>
    </view>

    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-icon">❤️</view>
      <view class="menu-text">我的收藏</view>
      <view class="menu-arrow">›</view>
    </view>

    <!-- 管理员功能 -->
    <view class="menu-item admin-item" bindtap="goToAdmin" wx:if="{{isAdmin}}">
      <view class="menu-icon">🛠️</view>
      <view class="menu-text">
        <text>内容管理</text>
        <view class="menu-sub">审核学生、管理课程</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- 退出按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <view class="bottom-space"></view>
</view>
