<!-- pages/my-favorites/my-favorites.wxml -->
<view class="container">
  <view class="header">
    <view class="title">❤️ 我的收藏</view>
    <view class="subtitle">查看你收藏的知识点，方便复习</view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view class="fav-list" wx:else>
    <view
      class="fav-card"
      wx:for="{{favorites}}"
      wx:key="_id"
      data-lesson="{{item.lessonId}}"
      data-chapter="{{item.chapterId}}"
      data-course="{{item.courseId}}"
      data-title="{{item.lessonTitle}}"
      bindtap="goToLesson"
    >
      <view class="fav-icon">📌</view>
      <view class="fav-content">
        <view class="lesson-title">{{item.lessonTitle}}</view>
        <view class="lesson-meta" wx:if="{{item.chapterTitle}}">{{item.chapterTitle}}</view>
      </view>
      <view class="fav-arrow">›</view>
    </view>

    <view class="empty-state" wx:if="{{favorites.length === 0}}">
      <view class="icon">🤍</view>
      <view class="text">暂无收藏</view>
      <view class="text" style="font-size: 24rpx; margin-top: 10rpx;">
        进入知识点详情页，点击"收藏"按钮添加
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
