.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.exam-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.2s;
}

.exam-card:active {
  transform: scale(0.98);
}

.exam-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.exam-info {
  flex: 1;
  min-width: 0;
}

.exam-name {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.exam-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.exam-arrow {
  font-size: 60rpx;
  opacity: 0.7;
  flex-shrink: 0;
}
