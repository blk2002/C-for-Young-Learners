/* pages/favorites/favorites.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.course-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin: 0 10rpx;
  border-radius: 12rpx;
  background: #F5F7FA;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
}

.tab-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 500;
}

.course-header {
  padding: 40rpx 30rpx 30rpx;
}

.course-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.course-desc {
  font-size: 26rpx;
  color: #999;
}

.entry-cards {
  padding: 20rpx 30rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.entry-card:active {
  background: #F5F7FA;
  transform: scale(0.98);
}

.card-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  width: 80rpx;
  text-align: center;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
}

.card-arrow {
  font-size: 48rpx;
  color: #CCC;
}