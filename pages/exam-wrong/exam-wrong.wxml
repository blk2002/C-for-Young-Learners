<!-- pages/exam-wrong/exam-wrong.wxml -->
<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <view wx:else>
    <view class="page-title">{{courseName}} 等级考试错题</view>
    <view class="page-subtitle">选择考试类型查看错题</view>

    <view class="exam-list" wx:if="{{examTypes.length > 0}}">
      <view
        class="exam-card"
        wx:for="{{examTypes}}"
        wx:key="examType"
        style="background: linear-gradient(135deg, {{item.color}}, {{item.colorDark}});"
        bindtap="goToLevels"
        data-type="{{item.examType}}"
        data-name="{{item.examName}}"
      >
        <view class="exam-icon">{{item.icon}}</view>
        <view class="exam-info">
          <view class="exam-name">{{item.examName}}</view>
          <view class="exam-desc">已做错 {{item.wrongCount}} 题</view>
        </view>
        <view class="exam-arrow">›</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{examTypes.length === 0}}">
      <view class="empty-icon">🎉</view>
      <view class="empty-text">暂无等级考试错题</view>
      <view class="empty-sub">太棒了，继续保持！</view>
    </view>
  </view>
</view>
