/* pages/admin-exercise-edit/admin-exercise-edit.wxss */
.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.content {
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 题目区域 */
.question-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.question-count {
  font-size: 26rpx;
  color: #666;
}

.question-add-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.add-question-btn {
  flex: 1;
  background: #E8F4FD;
  color: #4A90E2;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx dashed #4A90E2;
}

.add-question-btn:active {
  background: #D0E8FA;
}

.question-list {
  margin-top: 10rpx;
}

.question-item {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #4A90E2;
}

.question-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.question-index {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.question-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #E8F4FD;
  color: #4A90E2;
}

.question-type-tag.fill {
  background: #FFF3E0;
  color: #FF9800;
}

.question-preview {
  font-size: 28rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.question-actions {
  display: flex;
  gap: 12rpx;
}

.q-action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.q-action-btn.blue {
  background: #D0E8FA;
  color: #4A90E2;
}

.q-action-btn.orange {
  background: #FFE8CC;
  color: #FF9800;
}

.q-action-btn.red {
  background: #F8D7DA;
  color: #DC3545;
}

.empty-questions {
  text-align: center;
  padding: 60rpx 20rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.empty-questions .empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-questions .empty-hint {
  font-size: 24rpx;
  color: #BBB;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  flex: 1;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.textarea {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 150rpx;
  line-height: 1.6;
}

.input {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer button {
  flex: 1;
  margin: 0;
}

.btn-secondary {
  background: #F5F7FA;
  color: #666;
  font-size: 28rpx;
}

.btn-primary {
  background: #4A90E2;
  color: #fff;
  font-size: 28rpx;
}

.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  background: #fff;
}

.type-option.active {
  border-color: #4A90E2;
  background: #E8F4FD;
  color: #4A90E2;
  font-weight: 500;
}

.answer-selector {
  display: flex;
  gap: 16rpx;
}

.answer-option {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E0E0E0;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background: #fff;
}

.answer-option.active {
  border-color: #4A90E2;
  background: #4A90E2;
  color: #fff;
}

.bottom-space {
  height: 40rpx;
}