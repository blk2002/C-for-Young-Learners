.container {
  min-height: 100vh;
  background: #F5F7FA;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

.practice-container {
  padding: 20rpx;
}

.progress-header {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #4A90E2;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.question-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.question-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-wrap: wrap;
}

.question-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.question-type-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #E8F4FF;
  color: #4A90E2;
  font-size: 22rpx;
  border-radius: 20rpx;
}

.question-type-tag.fill {
  background: #FFF7E6;
  color: #FAAD14;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 28rpx;
  word-break: break-all;
  white-space: normal;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.option-item:active {
  background: #F0F0F0;
}

.option-item.selected {
  background: #E8F4FF;
  border-color: #4A90E2;
}

.option-item.disabled {
  opacity: 0.7;
  pointer-events: none;
}

.option-item.correct {
  background: #F0FFF0;
  border-color: #52C41A;
}

.option-item.right-answer {
  background: #FFFBE6;
  border-color: #FAAD14;
}

.option-letter {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  color: #999;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.option-item.selected .option-letter {
  background: #4A90E2;
  color: #fff;
}

.option-item.correct .option-letter {
  background: #52C41A;
  color: #fff;
}

.option-item.right-answer .option-letter {
  background: #FAAD14;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
}

.fill-input-wrap {
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 10rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 80rpx;
  box-sizing: border-box;
}

.input.disabled {
  background: #F5F5F5;
  color: #999;
}

.result-section {
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.result-correct {
  font-size: 28rpx;
  color: #52C41A;
  font-weight: bold;
}

.result-wrong {
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: bold;
  word-break: break-all;
  white-space: normal;
}

.answer-section {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #FAFAFA;
  border-radius: 10rpx;
}

.answer-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
}

.explanation-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.explanation-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  word-break: break-all;
  white-space: normal;
}

.nav-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  background: #fff;
  border: 2rpx solid #E8E8E8;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.nav-btn:active {
  background: #F5F5F5;
}

.nav-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.submit-section {
  margin-bottom: 20rpx;
}

.submit-btn {
  background: #4A90E2;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 12rpx;
}

.submit-btn:active {
  opacity: 0.8;
}

.result-summary {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.result-summary text {
  color: #4A90E2;
  font-weight: bold;
}

.bottom-space {
  height: 40rpx;
}
